# =============================================================================
# BAA 项目配置
# 复制为 .env 并填入实际值
# =============================================================================

# ── API 配置 ──────────────────────────────────────────────
BAA_PORT=8000                    # 服务端口
BAA_WORKERS=4                    # Gunicorn worker 数（CPU 密集型建议 2-4）
BAA_API_KEY=                     # 管理密钥（空=开发模式，不校验）

# ── 数据存储 ──────────────────────────────────────────────
BAA_DATA_DIR=/app/data           # 数据目录（上传文件/密钥/日志/模型）

# ── 密钥配置 ──────────────────────────────────────────────
BAA_KEY_TTL_DAYS=90              # API 密钥默认有效期（天）
BAA_KEY_RATE_LIMIT=60            # 每分钟最大请求数

# ── Docker 部署 ───────────────────────────────────────────
# docker-compose up -d
# docker-compose logs -f